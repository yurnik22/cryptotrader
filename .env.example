# Copy to `.env` (gitignored). Optional overrides for config.yaml / secrets.

# CRYPTOTRADER_CONFIG_PATH=/absolute/path/to/config.yaml

# Database overrides (merge into database.* from YAML)
# CRYPTOTRADER_DB_HOST=localhost
# CRYPTOTRADER_DB_PORT=3306
# CRYPTOTRADER_DB_USER=cryptotrader
# CRYPTOTRADER_DB_PASSWORD=secret
# CRYPTOTRADER_DB_NAME=cryptotrader

# Revolut X (when exchange: revolut and use_stub: false)
# CRYPTOTRADER_REVOLUT_API_KEY=
